{
  "manifest_version": 3,
  "name": "Lord of the Tabs",
  "version": "2.6",
  "description": "High-performance tab management with List/Grid views, IndexedDB history, and Google Sheets Backup.",
  "permissions": [
    "tabs",
    "windows",
    "activeTab",
    "storage",
    "identity",
    "scripting",
    "history",
    "favicon",
    "alarms",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["gemini_content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo_transparent.png",
      "48": "logo_transparent.png",
      "128": "logo_transparent.png"
    }
  },
  "icons": {
    "16": "logo_transparent.png",
    "48": "logo_transparent.png",
    "128": "logo_transparent.png"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },
  "commands": {
    "panic-close": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Trigger Instant Panic Close"
    },
    "add-to-unsafe": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Add current domain to unsafe list and close tab"
    }
  }
}
